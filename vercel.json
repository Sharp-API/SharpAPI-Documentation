    {
      "source": "/sdks",
      "destination": "/en/sdks/typescript",
      "permanent": true
    },
    {
      "source": "/sdks/:path*",
      "destination": "/en/sdks/:path*",
      "permanent": true
    },
    {
      "source": "/examples",
      "destination": "/en/examples/arbitrage-scanner",
      "permanent": true
    },
    {
      "source": "/examples/:path*",
      "destination": "/en/examples/:path*",
      "permanent": true
    },
    {
      "source": "/authentication",
      "destination": "/en/authentication",
      "permanent": true
